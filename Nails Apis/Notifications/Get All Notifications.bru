meta {
  name: Get All Notifications
  type: http
  seq: 2
}

get {
  url: {{base_url}}/v1/notifications?per_page=10&page=1
  body: none
  auth: bearer
}

params:query {
  per_page: 10
  page: 1
}

auth:bearer {
  token: {{super_adminToken}}
}

settings {
  encodeUrl: true
}

docs {
  Get a paginated list of all notifications for the authenticated user.
}
