meta {
  name: Mark All Notifications as Read
  type: http
  seq: 5
}

post {
  url: {{base_url}}/v1/notifications/mark-all-as-read
  body: none
  auth: bearer
}

auth:bearer {
  token: {{super_adminToken}}
}

settings {
  encodeUrl: true
}

docs {
  Marks all unread notifications for the authenticated user as read.
}
