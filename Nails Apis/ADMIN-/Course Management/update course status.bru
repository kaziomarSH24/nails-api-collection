meta {
  name: update course status
  type: http
  seq: 6
}

put {
  url: {{base_url}}/v1/admin/courses/:courseId/status?is_published=0
  body: none
  auth: bearer
}

params:query {
  is_published: 0
}

params:path {
  courseId: 9
}

auth:bearer {
  token: {{super_adminToken}}
}

settings {
  encodeUrl: true
}
