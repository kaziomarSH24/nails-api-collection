meta {
  name: Create Course
  type: http
  seq: 1
}

post {
  url: {{base_url}}/v1/admin/courses/
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{super_adminToken}}
}

body:multipart-form {
  title: demo course
  description: demo description
  price: 30
  thumbnail: @file(/C:/Users/bdCalling/Downloads/ChatGPT Image Jan 3, 2026, 12_06_45 PM.png)
  reward_points: 50
  duration: 7 hours
  instructor: ishan
}

settings {
  encodeUrl: true
}

docs {
  # Create Course
  
  ## Overview
  
  This endpoint creates a new course in the system. It allows administrators to add courses with details such as title, description, pricing, reward points, and duration.
  
  ## Endpoint Details
  
  - **Method:** `POST`
      
  - **URL:** `{{baseIP_url}}/v1/admin/courses/`
      
  - **Content-Type:** `multipart/form-data`
      
  
  ## Authentication
  
  This endpoint requires admin authentication. Include a valid admin token in your request headers.
  
  ## Request Parameters
  
  ### Form-Data Parameters
  
  | Parameter | Type | Required | Description |
  | --- | --- | --- | --- |
  | `title` | string | Yes | The course title. This is the main heading that will be displayed for the course. |
  | `description` | string | Yes | Detailed course description. Provide comprehensive information about the course content, objectives, and what students will learn. |
  | `price` | number | Yes | Course price in decimal format (e.g., 49.99). Represents the cost for enrolling in the course. |
  | `reward_points` | number | Yes | Points awarded to users upon course completion. Used for gamification and user engagement. |
  | `duration` | string | Yes | Course duration (e.g., "5 hours", "3 weeks"). Indicates the expected time commitment for completing the course. |
  | `thumbnail` | file | Optional | Course thumbnail image file. Upload an image that represents the course visually. |
  
  ## Response
  
  ### Success Response (201 Created)
  
  ``` json
  {
    "data": {
      "id": 2,
      "title": "Course Title",
      "description": "Course Description",
      "thumbnail": "http://example.com/storage/courses/thumbnail.jpg",
      "is_published": null,
      "created_at": "2026-01-15T05:28:16.000000Z",
      "updated_at": "2026-01-15T05:28:16.000000Z"
    },
    "ok": true,
    "message": "Course created successfully."
  }
  
   ```
  
  ### Response Fields
  
  - `id`: Unique identifier for the newly created course
      
  - `title`: The course title as provided
      
  - `description`: The course description as provided
      
  - `thumbnail`: URL to the uploaded thumbnail image (if provided)
      
  - `is_published`: Publication status (null by default)
      
  - `created_at`: Timestamp when the course was created
      
  - `updated_at`: Timestamp when the course was last updated
      
  - `ok`: Boolean indicating successful operation
      
  - `message`: Success message confirming course creation
}
