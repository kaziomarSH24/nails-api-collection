meta {
  name: Income Chart
  type: http
  seq: 2
}

get {
  url: {{base_url}}/v1/admin/chart/income?filter=weekly
  body: multipartForm
  auth: bearer
}

params:query {
  filter: weekly
  ~filter: monthly
}

auth:bearer {
  token: {{super_adminToken}}
}

body:multipart-form {
  question: {{$randomLoremLines}}
  answer: {{$randomLoremSentence}}
  is_active: 1
}

settings {
  encodeUrl: true
}
