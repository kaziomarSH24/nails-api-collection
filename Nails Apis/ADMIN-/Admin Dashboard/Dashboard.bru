meta {
  name: Dashboard
  type: http
  seq: 1
}

get {
  url: {{base_url}}/v1/admin/dashboard?filter=monthly
  body: multipartForm
  auth: bearer
}

params:query {
  filter: monthly
}

auth:bearer {
  token: {{super_adminToken}}
}

body:multipart-form {
  question: {{$randomLoremLines}}
  answer: {{$randomLoremSentence}}
  is_active: 1
}

settings {
  encodeUrl: true
}
