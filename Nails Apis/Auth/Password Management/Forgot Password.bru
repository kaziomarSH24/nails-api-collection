meta {
  name: Forgot Password
  type: http
  seq: 1
}

post {
  url: {{base_url}}/v1/auth/forgot-password
  body: multipartForm
  auth: inherit
}

headers {
  Accept: application/json
}

body:multipart-form {
  email: superadmin@yopmail.com
}

settings {
  encodeUrl: true
}

docs {
  Requests a password reset OTP/Link.
}
