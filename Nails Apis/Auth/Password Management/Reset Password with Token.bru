meta {
  name: Reset Password with Token
  type: http
  seq: 3
}

post {
  url: {{base_url}}/v1/auth/reset-password-with-token
  body: multipartForm
  auth: inherit
}

headers {
  Accept: application/json
}

body:multipart-form {
  email: test@example.com
  reset_token: {{reset_token}}
  password: newpassword123
  password_confirmation: newpassword123
}

settings {
  encodeUrl: true
}

docs {
  Resets the password using the temporary token and a new password.
}
