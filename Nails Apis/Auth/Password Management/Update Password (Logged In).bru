meta {
  name: Update Password (Logged In)
  type: http
  seq: 4
}

post {
  url: {{base_url}}/v1/auth/update-password
  body: multipartForm
  auth: inherit
}

headers {
  Authorization: Bearer {{auth_token}}
  ~Accept: application/json
}

body:multipart-form {
  current_password: 11111111
  new_password: newpassword123
  new_password_confirmation: newpassword123
}

settings {
  encodeUrl: true
}

docs {
  Changes the password for a logged-in user.
}
