meta {
  name: Update Appointment Status
  type: http
  seq: 7
}

put {
  url: {{base_url}}/v1/appointments/:appointmentId/status
  body: multipartForm
  auth: bearer
}

params:path {
  appointmentId: 3
}

auth:bearer {
  token: {{userToken}}
}

body:multipart-form {
  status: completed
}

settings {
  encodeUrl: true
}
