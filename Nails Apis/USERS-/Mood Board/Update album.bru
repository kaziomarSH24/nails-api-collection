meta {
  name: Update album
  type: http
  seq: 2
}

post {
  url: {{base_url}}/v1/mood-boards/:albumId
  body: multipartForm
  auth: bearer
}

params:path {
  albumId: 2
}

auth:bearer {
  token: {{userToken}}
}

body:multipart-form {
  name: new album update
  cover_image: @file(/C:/Users/kazio/Downloads/Linkedin cover for Omar faruk (1).jpg)
  _method: PUT
}

settings {
  encodeUrl: true
}
