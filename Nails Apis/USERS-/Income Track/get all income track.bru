meta {
  name: get all income track
  type: http
  seq: 2
}

get {
  url: {{base_url}}/v1/finance-records/?filter[date_between]=2026-01-19, 2026-02-01
  body: none
  auth: bearer
}

params:query {
  filter[date_between]: 2026-01-19, 2026-02-01
  ~filter[client_or_vendor_name]: bb Corporation
  ~sort: -created_at
  ~filter[type]: income
  ~"page ": 2
  ~per_page: 1
}

auth:bearer {
  token: {{userToken}}
}

settings {
  encodeUrl: true
}
