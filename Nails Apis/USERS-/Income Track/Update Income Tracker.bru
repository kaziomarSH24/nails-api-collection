meta {
  name: Update Income Tracker
  type: http
  seq: 3
}

put {
  url: {{base_url}}/v1/finance-records/:id
  body: multipartForm
  auth: bearer
}

params:path {
  id: 1
}

auth:bearer {
  token: {{userToken}}
}

body:multipart-form {
  type:  income
  amount:  1500
  category:  Project Payment
  record_date:  2021-12-31
  client_or_vendor_name:  ABC Corporation
  notes:  January development payment
}

settings {
  encodeUrl: true
}
