meta {
  name: create todos
  type: http
  seq: 1
}

post {
  url: {{base_url}}/v1/todos
  body: multipartForm
  auth: bearer
}

params:query {
  ~filter[client_or_vendor_name]: bb Corporation
  ~sort: -created_at
  ~filter[type]: income
  ~"page ": 2
  ~per_page: 1
}

auth:bearer {
  token: {{userToken}}
}

body:multipart-form {
  title: {{$randomLoremSentence}}
  due_date: 2026-02-02 14:30:00
  description: {{$randomLoremSentences}}
}

settings {
  encodeUrl: true
}
