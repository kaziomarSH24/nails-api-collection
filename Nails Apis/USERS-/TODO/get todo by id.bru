meta {
  name: get todo by id
  type: http
  seq: 3
}

get {
  url: {{base_url}}/v1/todos/1
  body: multipartForm
  auth: bearer
}

params:query {
  ~sort: -due_date
  ~"page ": 2
  ~per_page: 1
}

auth:bearer {
  token: {{userToken}}
}

body:multipart-form {
  title: {{$randomLoremSentence}}
  due_date: 2026-02-02 14:30:00
  description: {{$randomLoremSentences}}
}

settings {
  encodeUrl: true
}
