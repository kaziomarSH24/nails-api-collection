meta {
  name: Order History
  type: http
  seq: 2
}

get {
  url: {{base_url}}/v1/shop/orders?sort=-created_at
  body: multipartForm
  auth: bearer
}

params:query {
  sort: -created_at
}

auth:bearer {
  token: {{userToken}}
}

body:multipart-form {
  first_name: Kazi Omar
