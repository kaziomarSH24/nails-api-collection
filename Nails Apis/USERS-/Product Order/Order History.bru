  items[0][quantity]:  2
  items[0][price]:  899.99
  shipping_address[address1]:  House 12, Road 5, Dhanmondi
  shipping_address[zip]: HA2 6AE
  shipping_address[city]:  Dhaka
  ~items[1][variant_id]:  205
