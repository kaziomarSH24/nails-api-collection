meta {
  name: Get Faq
  type: http
  seq: 4
}

get {
  url: {{base_url}}/v1/settings/faqs
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{super_adminToken}}
}

body:multipart-form {
  question: {{$randomLoremLines}}
  answer: {{$randomLoremSentence}}
  is_active: 1
}

settings {
  encodeUrl: true
}
