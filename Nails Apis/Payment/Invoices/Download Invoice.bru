meta {
  name: Download Invoice
  type: http
  seq: 2
}

get {
  url: {{base_url}}/v1/payment/invoices/:invoiceId/download
  body: none
  auth: bearer
}

params:path {
  invoiceId: in_1S52KNE3HCOEW1L0odIbLbI3
}

auth:bearer {
  token: {{userToken}}
}

settings {
  encodeUrl: true
}

docs {
  Downloads a specific invoice as a PDF. Replace `in_...` with the actual Invoice ID.
}
